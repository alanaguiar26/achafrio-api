generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ProfileType {
  TECNICO
  EMPRESA
}

enum Plan {
  FREE
  STARTER
  PRO
  PREMIUM
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewChannel {
  WHATSAPP
  EMAIL
}

enum SubscriptionStatus {
  FREE
  PENDING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  RECEIVED
  CONFIRMED
  OVERDUE
  REFUNDED
  DELETED
  FAILED
}

enum QuoteStatus {
  NEW
  VIEWED
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  profile       Profile?
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id                    String            @id @default(cuid())
  userId                String            @unique
  type                  ProfileType
  name                  String
  slug                  String            @unique
  bio                   String?
  cpfCnpj               String?
  phone                 String?
  whatsapp              String?
  emailContact          String?
  website               String?
  city                  String
  state                 String
  zipCode               String?
  address               String?
  avatarUrl             String?
  plan                  Plan              @default(FREE)
  verified              Boolean           @default(false)
  verifiedAt            DateTime?
  active                Boolean           @default(true)
  featured              Boolean           @default(false)
  asaasCustomerId       String?
  averageRating         Float             @default(0)
  reviewsCount          Int               @default(0)
  viewsCount            Int               @default(0)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties           ProfileSpecialty[]
  cities                ProfileCity[]
  photos                Photo[]
  reviews               Review[]
  reviewTokens          ReviewToken[]
  subscription          Subscription?
  quotes                Quote[]
  views                 ProfileView[]
  verificationDocuments VerificationDoc[]

  @@index([state, city])
  @@index([plan, verified, active])
}

model Specialty {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  createdAt DateTime           @default(now())

  profiles ProfileSpecialty[]
}

model ProfileSpecialty {
  profileId   String
  specialtyId String
  createdAt   DateTime @default(now())

  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([profileId, specialtyId])
  @@index([specialtyId])
}

model ProfileCity {
  id        String   @id @default(cuid())
  profileId String
  city      String
  state     String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([state, city])
}

model Photo {
  id        String   @id @default(cuid())
  profileId String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Review {
  id           String       @id @default(cuid())
  profileId    String
  tokenId      String?      @unique
  reviewerName String
  rating       Int
  comment      String?
  ipHash       String?
  status       ReviewStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  approvedAt   DateTime?

  profile Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  token   ReviewToken? @relation(fields: [tokenId], references: [id])

  @@index([profileId, status])
}

model ReviewToken {
  id             String        @id @default(cuid())
  profileId      String
  token          String        @unique
  channel        ReviewChannel
  clientName     String?
  clientContact  String?
  expiresAt      DateTime
  usedAt         DateTime?
  requestedById  String
  createdAt      DateTime      @default(now())

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  review    Review?

  @@index([profileId])
  @@index([requestedById])
}

model Subscription {
  id                    String              @id @default(cuid())
  profileId             String              @unique
  plan                  Plan
  status                SubscriptionStatus  @default(PENDING)
  asaasSubscriptionId   String?             @unique
  asaasCustomerId       String?
  asaasPaymentLinkId    String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  nextDueDate           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id               String        @id @default(cuid())
  subscriptionId   String
  asaasPaymentId   String?       @unique
  invoiceUrl       String?
  billingType      String?
  amount           Float
  status           PaymentStatus @default(PENDING)
  externalReference String?
  dueDate          DateTime?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
}

model Quote {
  id          String      @id @default(cuid())
  profileId   String
  clientName  String
  clientPhone String
  clientEmail String?
  clientCity  String
  clientState String
  serviceType String?
  description String
  status      QuoteStatus @default(NEW)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
}

model ProfileView {
  id        String   @id @default(cuid())
  profileId String
  ipHash    String?
  date      DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, date])
}

model VerificationDoc {
  id          String             @id @default(cuid())
  profileId   String
  documentUrl String
  selfieUrl   String?
  status      VerificationStatus @default(PENDING)
  adminNote   String?
  reviewedAt  DateTime?
  createdAt   DateTime           @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventKey    String   @unique
  payload     String
  processedAt DateTime @default(now())

  @@index([provider])
}
